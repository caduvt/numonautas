module unidade_controle (
    input        clock,
    input        reset,
    input        reset_home,

    input        btn_iniciar,
    input        pc_pronto,
    input        acertou,
    input        errou,
    input        nivel_limite,
    input        fim_timer,

    output reg   zera_jogo,
    output reg   fpga_pronta,
    output reg   captura_gabarito,
    output reg   aguarda_player,
    output reg   valida_res,
    output reg   proximo_nivel,
    output reg   sinaliza_erro,
    output reg   vitoria
);

    localparam INICIO           = 4'd0,
               ESPERA_PC        = 4'd1,
               AGUARDAR_INPUT   = 4'd2,
               PROCESSAR_RES    = 4'd3,
               ACERTO           = 4'd4,
               ERRO             = 4'd5,
               CHECK_LVL        = 4'd6,
               MOSTRA_RES_ERRO  = 4'd7,
               FINAL_VITORIA    = 4'd8;

    reg [3:0] Eatual, Eprox;

    always @(posedge clock or posedge reset) begin
        if (reset || reset_home) Eatual <= INICIO;
        else                     Eatual <= Eprox;
    end

    always @(*) begin
        case (Eatual)
            INICIO:           Eprox = btn_iniciar ? ESPERA_PC : INICIO;

            ESPERA_PC:        Eprox = pc_pronto ? AGUARDAR_INPUT : ESPERA_PC;

            AGUARDAR_INPUT:   Eprox = (acertou || errou) ? PROCESSAR_RES : AGUARDAR_INPUT; 

            PROCESSAR_RES: begin
                if (acertou)      Eprox = ACERTO;
                else if (errou)   Eprox = ERRO;
                else              Eprox = PROCESSAR_RES;
            end

            ACERTO:           Eprox = CHECK_LVL;

            CHECK_LVL:        Eprox = nivel_limite ? FINAL_VITORIA : ESPERA_PC; // Se não for 15, pede nova fase ao PC

            ERRO:             Eprox = MOSTRA_RES_ERRO;

            MOSTRA_RES_ERRO:  Eprox = fim_timer ? AGUARDAR_INPUT : MOSTRA_RES_ERRO;

            FINAL_VITORIA:    Eprox = FINAL_VITORIA; 

            default:          Eprox = INICIO;
        endcase
    end

    always @(*) begin
        zera_jogo = 0; fpga_pronta = 0; captura_gabarito = 0; 
        aguarda_player = 0; valida_res = 0; 
        proximo_nivel = 0; sinaliza_erro = 0; vitoria = 0;

        case (Eatual)
            INICIO: begin
                zera_jogo = 1;
            end

            ESPERA_PC: begin
                fpga_pronta = 1;      
                captura_gabarito = 1; 
            end

            AGUARDAR_INPUT: begin
                aguarda_player = 1;
            end

            PROCESSAR_RES: begin
                valida_res = 1;
            end

            ACERTO: begin
                proximo_nivel = 1;
            end

            ERRO, MOSTRA_RES_ERRO: begin
                sinaliza_erro = 1;
            end

            FINAL_VITORIA: begin
                vitoria = 1;
            end
        endcase
    end

endmodule